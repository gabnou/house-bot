# Name shown in WhatsApp's Linked Devices list (max 20 chars)
WHATSAPP_APPNAME=HouseBot

# Ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral-small:22b
# Embedding model used for fast multilingual category classification
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
# How long Ollama keeps the model in RAM after the last request.
# Examples: 5m (default), 30m, 1h, -1 (never unload)
# OLLAMA_KEEP_ALIVE=5m

# Google Calendar
GOOGLE_CALENDAR_NAME=MyFamilyCalendar
CALENDAR_TIMEZONE=Europe/Madrid

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# WhatsApp partner JIDs (format: jid:name,jid:name — name is optional)
# The name is the WhatsApp display name shown in the install wizard.
PARTNER_LID=XXXXXXXXXXXXXXX@lid

# Whisper model for voice transcription
WHISPER_MODEL=small

# Morning briefing time in HH:MM format (default: 07:30, local time)
# BRIEFING_TIME=07:30

# Morning briefing language (default: English). Set to translate the briefing.
# Examples: Spanish, Italian, French, German, Portuguese
# BRIEFING_LANGUAGE=Spanish

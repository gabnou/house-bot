# Ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral-small:22b

# Google Calendar
GOOGLE_CALENDAR_NAME=MyFamilyCalendar
CALENDAR_TIMEZONE=Europe/Madrid

# AEMET (Spain national weather service)
AEMET_API_KEY=<your-aemet-key>

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# WhatsApp partner JIDs (comma-separated)
PARTNER_LID=XXXXXXXXXXXXXXX@lid,XXXXXXXXXXXXXXX@lid
PARTNER_NET=XXXXXXXXXXX@s.whatsapp.net,XXXXXXXXXXX@s.whatsapp.net

# Whisper model for voice transcription
WHISPER_MODEL=small

# Morning briefing time in HH:MM format (default: 07:30, local time)
# BRIEFING_TIME=07:30

# Morning briefing language (default: English). Set to translate the briefing.
# Examples: Spanish, Italian, French, German, Portuguese
# BRIEFING_LANGUAGE=Spanish
